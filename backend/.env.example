# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret-key

# JWT expiry in minutes (1440 = 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# SQLite database file path (relative to backend/)
DATABASE_URL=sqlite+aiosqlite:///./signalx.db

# Directory for uploaded attachments (relative to backend/)
UPLOAD_DIR=./uploads

# Maximum upload size in bytes (26214400 = 25 MB)
MAX_UPLOAD_SIZE_BYTES=26214400

# Frontend origin for CORS (comma-separated for multiple)
CORS_ORIGINS=http://localhost:3000
